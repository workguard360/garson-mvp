generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String         @id
  name      String
  address   String?
  tables    Table[]
  categories MenuCategory[]
  createdAt DateTime       @default(now())
}

model Table {
  id          String        @id
  branchId    String
  label       String
  qrTokenHash String        @unique
  branch      Branch        @relation(fields: [branchId], references: [id])
  seats       Seat[]
  sessions    TableSession[]
  createdAt   DateTime      @default(now())
}

model Seat {
  id      String     @id
  tableId String
  seatNo  Int
  table   Table      @relation(fields: [tableId], references: [id])
  claims  SeatClaim[]
  orders  Order[]
  @@unique([tableId, seatNo])
}

model TableSession {
  id        String      @id
  tableId   String
  expiresAt DateTime
  status    String
  table     Table       @relation(fields: [tableId], references: [id])
  claims    SeatClaim[]
  orders    Order[]
  createdAt DateTime    @default(now())
}

model SeatClaim {
  id                String       @id
  sessionId         String
  seatId            String
  clientFingerprint String
  claimedUntil      DateTime
  status            String
  session           TableSession @relation(fields: [sessionId], references: [id])
  seat              Seat         @relation(fields: [seatId], references: [id])
  createdAt         DateTime     @default(now())
  @@index([seatId, claimedUntil, status])
}

model MenuCategory {
  id        String     @id
  branchId  String
  name      String
  branch    Branch     @relation(fields: [branchId], references: [id])
  items     MenuItem[]
  createdAt DateTime   @default(now())
}

model MenuItem {
  id         String      @id
  categoryId String
  name       String
  price      Decimal     @db.Decimal(10, 2)
  allergens  Json
  imageUrl   String?
  isActive   Boolean     @default(true)
  category   MenuCategory @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
}

model Order {
  id             String       @id
  sessionId      String
  seatId         String
  status         String
  idempotencyKey String       @unique
  session        TableSession @relation(fields: [sessionId], references: [id])
  seat           Seat         @relation(fields: [seatId], references: [id])
  items          OrderItem[]
  createdAt      DateTime     @default(now())
}

model OrderItem {
  id      String   @id
  orderId String
  itemId  String
  qty     Int
  notes   String?
  order   Order    @relation(fields: [orderId], references: [id])
  item    MenuItem @relation(fields: [itemId], references: [id])
}